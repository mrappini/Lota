{
  "entities": {
    "Report": {
      "title": "Report",
      "description": "A crowd level report submitted by a user",
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["green", "yellow", "red"],
          "description": "The reported crowd level"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The server timestamp when the report was created"
        },
        "dayOfWeek": {
          "type": "integer",
          "description": "The day of the week (0-6)"
        },
        "hour": {
          "type": "integer",
          "description": "The hour of day (0-23)"
        },
        "userId": {
          "type": "string",
          "description": "The unique user ID from local storage"
        }
      },
      "required": ["status", "createdAt", "dayOfWeek", "hour", "userId"]
    }
  },
  "firestore": {
    "/reports/{reportId}": {
      "schema": "#/entities/Report",
      "description": "Collection of all crowd reports"
    }
  }
}
