rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net: Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Reports collection security rules
    match /reports/{reportId} {
      allow get, list: if true;
      allow create, update: if isValidId(reportId) 
        && isValidReport(request.resource.data)
        && (
          !reportId.matches('^rep_.*')
          || reportId.matches('^rep_' + request.resource.data.userId + '_[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        );
      allow delete: if false;
    }

    // Hardened ID validation
    function isValidId(id) {
      return id is string && id.size() <= 64 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Schema and boundary validation for Reports
    function isValidReport(data) {
      return data.keys().hasAll(['status', 'createdAt', 'dayOfWeek', 'hour', 'userId'])
        && data.keys().size() == 5
        && data.status is string
        && (data.status == 'green' || data.status == 'yellow' || data.status == 'red')
        && data.createdAt is timestamp
        && (data.dayOfWeek is int || data.dayOfWeek is float)
        && data.dayOfWeek >= 0 && data.dayOfWeek <= 6
        && (data.hour is int || data.hour is float)
        && data.hour >= 0 && data.hour <= 23
        && data.userId is string
        && data.userId.size() <= 40;
    }
  }
}
